{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@bogeychan/elysia-logger": "^0.1.10",
    "@elysiajs/cors": "^1.4.1",
    "@sinclair/typebox": "^0.34.49",
    "@skyclad-bun/db": "workspace:*",
    "@skyclad-bun/env": "workspace:*",
    "dotenv": "catalog:",
    "elysia": "^1.4.28",
    "fast-xml-parser": "^5.3.0",
    "marked": "^17.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@skyclad-bun/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
